NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
CORS_ORIGIN=*

# LLM
OPENAI_API_KEY=

# Vector DB (Pinecone)
PINECONE_API_KEY=
PINECONE_INDEX=

# LangSmith (optional tracing)
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# File processing
FILE_PROCESSING_DIR=tmp/uploads
FILE_CHUNK_SIZE=1000
FILE_CHUNK_OVERLAP=200
EMBEDDING_MODEL=llama-text-embed-v2
CHAT_MODEL=gpt-4o-mini
CHAT_TOP_K=10
CHAT_TEMPERATURE=0
PINECONE_BATCH_SIZE=100
MAX_UPLOAD_BYTES=20971520

# Ollama (local LLM) — used when chat request sends provider=ollama.
# Run `ollama serve` and `ollama pull qwen3.5:2b` before using it.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen3.5:2b
